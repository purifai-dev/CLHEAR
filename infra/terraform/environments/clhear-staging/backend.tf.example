# Copy to backend.tf and fill in. Use a dedicated S3 key for CLHear — never the same
# state key as Complied Influence (terraform.tfstate) unless you use workspaces
# and fully understand the blast radius.

# PurifAI default: same bucket + lock table as Complied Influence, unique key only.
# See backend.tf (tracked) or copy from terraform.tfvars.purifai-shared-vpc.example flow.

terraform {
  backend "s3" {
    bucket         = "complied-influence-tfstate-392932797125"
    key            = "clhear/staging/terraform.tfstate"
    region         = "us-east-1"
    encrypt        = true
    dynamodb_table = "complied-influence-tf-lock"
  }
}
