# Copy to backend.tf and fill in. Use a dedicated S3 key for CLHear — never the same
# state key as Complied Influence (terraform.tfstate) unless you use workspaces
# and fully understand the blast radius.

terraform {
  backend "s3" {
    bucket         = "YOUR_ORG_TERRAFORM_STATE_BUCKET"
    key            = "clhear/staging/terraform.tfstate"
    region         = "us-east-1"
    encrypt        = true
    dynamodb_table = "YOUR_TERRAFORM_LOCK_TABLE"
  }
}
