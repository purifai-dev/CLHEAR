# Copy to terraform.tfvars (gitignored) or use -var flags.
# Never commit real secrets.
#
# PurifAI shared VPC (account 392932797125): see also
#   terraform.tfvars.purifai-shared-vpc.example
#   docs/CLHEAR_PURIFAI_SHARED_VPC.md

aws_region   = "us-east-1"
environment  = "staging"
name_prefix  = "clhear-staging"
app_base_url = "https://clhear.ai"

# ── Recommended: shared PurifAI VPC (Complied Influence / platform) ─────────
# In the Complied Influence repo (after apply), add outputs if missing, then:
#   terraform output vpc_id
#   terraform output -json public_subnet_ids
#   terraform output -json private_subnet_ids
# Or use the AWS Console: VPC → Subnets (two public + two private in different AZs).
#
# vpc_id = "vpc-xxxxxxxx"
# public_subnet_ids  = ["subnet-aaaa", "subnet-bbbb"]
# private_subnet_ids = ["subnet-cccc", "subnet-dddd"]

# ── Dedicated CLHear-only VPC (extra NAT + uses VPC quota) ──────────────────
# Leave vpc_id / subnet vars unset or empty, and set:
# vpc_cidr = "10.42.0.0/16"

# Optional: ACM cert ARN in us-east-1 for HTTPS on the ALB.
# acm_certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/..."

# GitHub repo for OIDC deploy role.
# github_repository = "your-org/clhear-platform"

# Optional SMTP (smtp_pass → Secrets Manager).
# smtp_host = "email-smtp.us-east-1.amazonaws.com"
# smtp_user = "AKIAXXXXXXXX"
# smtp_pass = "your-smtp-secret"

# Anthropic / Claude — secret must exist in Secrets Manager (console); Terraform wires it to ECS.
# anthropic_secret_name = "Anthropic-clhear"
